---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>
			&copy; {today.getFullYear()} <a href="https://unchainit.tech">unchainit.tech</a>
		</p>
		<div class="footer-links">
			<a href="https://linkedin.com/in/aidasmarcink" target="_blank" rel="noopener">LinkedIn</a>
			<a href="https://github.com/AidasMIT" target="_blank" rel="noopener">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2em 2rem;
		border-top: 1px solid rgb(var(--gray-light));
		margin-top: 4em;
		background: #fff;
	}
	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	footer p {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0;
	}
	footer a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.8em;
	}
	footer a:hover { color: rgb(var(--black)); }
	.footer-links {
		display: flex;
		gap: 16px;
	}
	@media (max-width: 720px) {
		.footer-inner { flex-direction: column; gap: 8px; }
	}
</style>
