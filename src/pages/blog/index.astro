---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { width: 720px; }
			.page-title {
				font-size: 2em;
				margin-bottom: 0.25em;
			}
			.page-desc {
				color: rgb(var(--gray));
				margin-bottom: 2.5em;
				font-size: 1.05em;
			}
			.posts { list-style: none; margin: 0; padding: 0; }
			.posts li {
				padding: 1.5em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.posts li:first-child { padding-top: 0; }
			.posts li:last-child { border-bottom: none; }
			.posts a { text-decoration: none; display: block; }
			.posts a:hover .post-title { color: var(--accent); }
			.post-title {
				font-family: 'Space Grotesk', sans-serif;
				font-size: 1.35em;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.35em;
				line-height: 1.3;
				letter-spacing: -0.01em;
				transition: color 0.15s;
			}
			.post-desc {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin: 0 0 0.5em;
				line-height: 1.5;
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.8em;
				font-weight: 500;
			}
			@media (max-width: 720px) {
				.page-title { font-size: 1.5em; }
				.post-title { font-size: 1.15em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">Blog</h1>
			<p class="page-desc">Practical guides on building, shipping, and growing software products.</p>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<h2 class="post-title">{post.data.title}</h2>
							{post.data.description && <p class="post-desc">{post.data.description}</p>}
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
