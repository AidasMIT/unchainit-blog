---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				margin-bottom: 2.5em;
			}
			.page-label {
				display: inline-block;
				font-size: 0.75em;
				font-weight: 500;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: #059669;
				margin-bottom: 0.75em;
			}
			.page-title {
				font-size: 2.25em;
				margin-bottom: 0.25em;
			}
			.page-desc {
				color: rgb(var(--gray));
				font-size: 1.05em;
			}
			.posts { list-style: none; margin: 0; padding: 0; }
			.posts li { margin-bottom: 1em; }
			.post-card {
				display: block;
				text-decoration: none;
				padding: 1.5em;
				background: rgb(var(--gray-light));
				border: 1px solid transparent;
				border-radius: 16px;
				transition: all 0.2s;
			}
			.post-card:hover {
				background: #fff;
				border-color: #e2e8f0;
				box-shadow: 0 2px 8px rgba(0,0,0,0.04);
				transform: translateY(-1px);
				text-decoration: none;
			}
			.post-card:hover .post-title { color: #059669; }
			.post-title {
				font-family: 'DM Sans', sans-serif;
				font-size: 1.2em;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.35em;
				line-height: 1.35;
				transition: color 0.15s;
			}
			.post-desc {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0 0 0.5em;
				line-height: 1.5;
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.75em;
				font-weight: 500;
			}
			@media (max-width: 720px) {
				.page-title { font-size: 1.75em; }
			}
		</style>
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MC7XSN8T" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<Header />
		<main>
			<div class="page-header">
				<span class="page-label">All Posts</span>
				<h1 class="page-title">Blog</h1>
				<p class="page-desc">Practical guides on building, shipping, and growing software products.</p>
			</div>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<h2 class="post-title">{post.data.title}</h2>
							{post.data.description && <p class="post-desc">{post.data.description}</p>}
							<span class="post-meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
